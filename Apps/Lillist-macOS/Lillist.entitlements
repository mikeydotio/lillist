<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>com.apple.security.app-sandbox</key>
    <true/>
    <key>com.apple.security.files.user-selected.read-write</key>
    <true/>
    <key>com.apple.security.network.client</key>
    <true/>
    <key>com.apple.security.application-groups</key>
    <array>
        <string>group.io.mikeydotio.Lillist</string>
    </array>
    <key>com.apple.developer.icloud-container-identifiers</key>
    <array>
        <string>iCloud.com.mikeydotio.lillist</string>
    </array>
    <key>com.apple.developer.icloud-services</key>
    <array>
        <string>CloudKit</string>
    </array>
    <!-- The macOS test build is `method=development`-signed (see
         `.deployit/ExportOptions.macos.plist`), which puts it on the
         Development CloudKit database — same as the iOS test build, where the
         data lives. Keep this `Development` to match. NOTE: `xcodebuild
         -exportArchive` re-stamps this from the export options + profile, so
         it is the *signed binary* that matters, not this source value — verify
         with `codesign -d --entitlements :- <app> | plutil -p -`. A Developer-ID
         export would force this to Production (Apple rejects Development for
         developer-id); that path is deferred to the shipping cutover. See
         engineering-notes 2026-06-23 and the CloudKit section of CLAUDE.md. -->
    <key>com.apple.developer.icloud-container-environment</key>
    <string>Development</string>
    <!-- NSPersistentCloudKitContainer requires the Push Notifications
         capability to establish its CloudKit change subscription. The shared
         App ID (io.mikeydotio.Lillist) already has Push + CloudKit enabled
         via the iOS target. -->
    <key>aps-environment</key>
    <string>development</string>
</dict>
</plist>
