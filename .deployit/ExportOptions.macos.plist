<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Project-local export options for `/deployit` macOS builds. deployit's
  ExportOptions ladder (bin/deployit-cli: DEPLOYIT_EXPORT_OPTIONS_PATH env ->
  .deployit/ExportOptions.<platform>.plist -> bundled default) picks this up
  automatically; it mirrors deployit's bundled developer-id default and adds
  the load-bearing iCloud-environment pin.

  Why this file exists (hard-won — see docs/engineering-notes.md):
  `xcodebuild -exportArchive` RE-STAMPS the
  `com.apple.developer.icloud-container-environment` entitlement from the
  export options' `iCloudContainerEnvironment` key. For a developer-id export
  the default when the key is ABSENT is Production — so the `Development`
  value declared in Apps/Lillist-macOS/Lillist.entitlements was being silently
  overwritten to Production at export, putting every Developer-ID test build on
  the (schema-less, deferred) Production CloudKit database. That is a different
  database from the Development-signed iOS test build, so nothing synced and a
  first-time "replace this device with iCloud" import hit CKError.partialFailure.

  Pinning Development here makes the Developer-ID test build share the one
  Development database with the iOS build, matching the entitlements source.
  At the eventual production cutover, change this to Production (App Store
  exports are always Production regardless).
-->
<plist version="1.0">
<dict>
    <key>method</key>
    <string>developer-id</string>
    <key>signingStyle</key>
    <string>automatic</string>
    <key>iCloudContainerEnvironment</key>
    <string>Development</string>
</dict>
</plist>
