<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Project-local export options for `/deployit` macOS builds. deployit's
  ExportOptions ladder (bin/deployit-cli: DEPLOYIT_EXPORT_OPTIONS_PATH env ->
  .deployit/ExportOptions.<platform>.plist -> bundled default) picks this up
  automatically; it mirrors deployit's bundled developer-id default and pins
  the iCloud CloudKit environment EXPLICITLY.

  Why this is pinned to Production (hard-won — see docs/engineering-notes.md
  2026-06-23):
  `xcodebuild -exportArchive` RE-STAMPS the
  `com.apple.developer.icloud-container-environment` entitlement from this
  `iCloudContainerEnvironment` key, OVERRIDING whatever the source
  Apps/Lillist-macOS/Lillist.entitlements declares. For a `developer-id`
  export the ONLY value Apple permits is `Production` — setting `Development`
  fails the export with:
      exportArchive ... key "iCloudContainerEnvironment": value "Development"
      is not allowed
  So a Developer-ID (distribution-signed) macOS build is *always* on the
  Production CloudKit database. To put a macOS build on Development you must
  `method = development`-sign it instead (registered Macs only) — do NOT
  re-attempt a Development pin here; Apple rejects it. This explicit pin
  exists to document that and prevent the regression.
-->
<plist version="1.0">
<dict>
    <key>method</key>
    <string>developer-id</string>
    <key>signingStyle</key>
    <string>automatic</string>
    <key>iCloudContainerEnvironment</key>
    <string>Production</string>
</dict>
</plist>
